#!/bin/bash
# OpenClaw Safety Guard - Safety Check Command Wrapper
# 用法：safety-check "消息内容"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/scripts/safety_check.py"

# 使用 Skill 目录内的虚拟环境
if [ -f "$SCRIPT_DIR/venv/bin/activate" ]; then
    source "$SCRIPT_DIR/venv/bin/activate"
fi

# 执行 Python 脚本
python3 "$PYTHON_SCRIPT" "$@"
